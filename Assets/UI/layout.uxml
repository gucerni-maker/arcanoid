    <ui:Label text="Pulsa Barra Espacio Para Continuar" name="continuar" style="position: absolute; -unity-font-style: bold; font-size: 20px; color: rgb(255, 235, 4); top: 298px; left: 158px; width: 395px; height: 92px; overflow: visible; flex-wrap: wrap; flex-direction: row; flex-basis: auto; white-space: pre-wrap; -unity-text-align: upper-center;"/>
